# База данных
DATABASE_URL=postgresql://devuser:devpass@localhost:5433/anjdjey_downloader

# Redis
REDIS_URL=redis://localhost:6379

# Сервер
NODE_ENV=development
PORT=3000
UPLOAD_DIR=./downloads

# Telegram бот
BOT_TOKEN=your-telegram-bot-token
BOT_MODE=polling
WEBHOOK_DOMAIN=
WEBHOOK_SECRET=random-webhook-secret

# yt-dlp
YTDLP_PATH=yt-dlp
YTDLP_COOKIES_DIR=./cookies

# Прокси (опционально)
PROXY_ENABLED=false

# Очистка файлов
FILE_TTL_HOURS=2
CLEANUP_INTERVAL_MINUTES=30

# Лимиты
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
